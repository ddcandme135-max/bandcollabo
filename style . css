body{
background:#0b0b0b;
color:white;
font-family:sans-serif;
margin:0;
}

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 40px;
background:#111;
}

.logo{
font-size:24px;
font-weight:bold;
}

.menu a{
margin-left:20px;
color:white;
text-decoration:none;
font-size:16px;
}

.hero{
text-align:center;
margin-top:120px;
}

.hero h1{
font-size:60px;
}

.hero p{
color:#aaa;
margin-bottom:30px;
}

button{
background:#7a3cff;
border:none;
padding:15px 30px;
border-radius:10px;
color:white;
font-size:18px;
cursor:pointer;
}